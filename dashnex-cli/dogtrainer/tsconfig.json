{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": false,

    "paths": {
      "@/*": ["./src/*"],
      "next": ["./node_modules/vinext/dist/shims/metadata"],
      "next/*": ["./node_modules/vinext/dist/shims/*"],
    },
    "target": "ES2017"
  },
  "include": ["**/*.ts", "**/*.tsx", "test.ss"],
  "exclude": ["node_modules", "packages/*", "**/node_modules/**", "src/dashnex/**"]
}
